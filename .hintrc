{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": "off",
    "no-inline-styles": "off",
    "button-type": "off",
    "axe/name-role-value": "off",
    "axe/text-alternatives": "off",
    "typescript-config/consistent-casing": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "orphans",
          "widows",
          "min-height: auto"
        ]
      }
    ]
  }
}